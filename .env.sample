# Semantic Scholar API Key (required)
S2_API_KEY=

# Groq API Key (required)
GROQ_API_KEY=

# PostgreSQL connection
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=literature_db

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=papers_sparse
QDRANT_BATCH_SIZE=64

# Pipeline feature flags (set to 0 to skip a step)
RUN_EMBEDDING_STEP=1
RUN_QDRANT_STEP=1

# Embedding preview log
EMBEDDING_PREVIEW_PATH=logs/embedding_preview.jsonl
EMBEDDING_PREVIEW_COUNT=100
